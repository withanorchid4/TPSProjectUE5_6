		<DisplayString Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type &amp;&amp; ((python312.dll!PyLongObject*)this)->long_value.lv_tag &lt; 16">(pyint) {((int)1 - (int)(((python312.dll!PyLongObject*)this)->long_value.lv_tag &amp; 3)) * (long long)((python312.dll!PyLongObject*)this)->long_value.ob_digit[0]} </DisplayString>

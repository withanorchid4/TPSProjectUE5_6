			<!--PyLongObject - 简化展开-->
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type" Name="[lv_tag]">((python312.dll!PyLongObject*)this)->long_value.lv_tag</Item>
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type" Name="[is_compact]">((python312.dll!PyLongObject*)this)->long_value.lv_tag &lt; 16</Item>
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type" Name="[ndigits]">(((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3)</Item>
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type" Name="[bits]">(((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3) * 30</Item>
			<!-- 紧凑模式显示计算值 -->			
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type &amp;&amp; ((python312.dll!PyLongObject*)this)->long_value.lv_tag &lt; 16" Name="[value]">((int)1 - (int)(((python312.dll!PyLongObject*)this)->long_value.lv_tag &amp; 3)) * (long long)((python312.dll!PyLongObject*)this)->long_value.ob_digit[0]</Item>
			<Synthetic Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type &amp;&amp; (((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3) &gt; 0" Name="[computed_value]">
				<Expand>
					<CustomListItems>
						<Variable Name="i" InitialValue="0"/>
						<Variable Name="result" InitialValue="0ULL"/>
						<Variable Name="power" InitialValue="1ULL"/>
						<Variable Name="ndigits" InitialValue="(((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3)"/>
						<Variable Name="digits" InitialValue="(uint32_t*)(&amp;((python312.dll!PyLongObject*)this)->long_value.ob_digit)"/>
						<Variable Name="lv_tag" InitialValue="((python312.dll!PyLongObject*)this)->long_value.lv_tag"/>
						<Variable Name="sign_bits" InitialValue="(int)(lv_tag &amp; 3)"/>
						<Variable Name="sign" InitialValue="1 - sign_bits"/>
						<Variable Name="overflow" InitialValue="0"/>						
						<!-- 只处理最多2个digits，因为2^60 < 2^63 保证不溢出 -->
						<Loop Condition="i &lt; ndigits &amp;&amp; i &lt; 2 &amp;&amp; overflow == 0">
							<Exec>result = result + ((unsigned long long)digits[i]) * power</Exec>
							<Exec>power = power * 1073741824ULL</Exec>
							<Exec>i = i + 1</Exec>
						</Loop>						
						<!-- 如果超过2个digits，标记为溢出 -->
						<Exec Condition="ndigits &gt; 2">overflow = 1</Exec>						
						<Item Name="[sign_bits]">sign_bits</Item>
						<Item Name="[sign]">sign</Item>
						<Item Name="[ndigits_used]">i</Item>
						<Item Name="[unsigned_result]">result</Item>						
						<!-- 显示最终值 -->
						<Item Condition="overflow == 0 &amp;&amp; sign &gt;= 0 &amp;&amp; result &lt;= 9223372036854775807ULL" Name="[value]">(long long)result</Item>
						<Item Condition="overflow == 0 &amp;&amp; sign &lt; 0 &amp;&amp; result &lt;= 9223372036854775808ULL" Name="[value]">-(long long)result</Item>
						<Item Condition="overflow != 0 || (sign &gt;= 0 &amp;&amp; result &gt; 9223372036854775807ULL) || (sign &lt; 0 &amp;&amp; result &gt; 9223372036854775808ULL)" Name="[value]">"overflow (too large for c++)"</Item>
					</CustomListItems>
				</Expand>
			</Synthetic>
			<Synthetic Condition="(void*)ob_type==(void*)&amp;python312.dll!PyLong_Type &amp;&amp; (((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3) &gt; 0" Name="[digits]">
				<DisplayString>digits[{(((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3)}] ({(((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3) * 30} bits) value=sum(val * (2**30)**i for i, val in enumerate(digit))</DisplayString>
				<Expand>
					<ArrayItems>
						<Size>(((python312.dll!PyLongObject*)this)->long_value.lv_tag &gt;&gt; 3)</Size>
						<ValuePointer>(uint32_t*)(&amp;((python312.dll!PyLongObject*)this)->long_value.ob_digit)</ValuePointer>
					</ArrayItems>
				</Expand>
			</Synthetic>

			</ArrayItems>
			<!-- PyDictObject 参考源码DK_ENTRIES-->
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyDict_Type" Name="[pyobj]">(python312.dll!PyDictObject*)this</Item>
			<Item Condition="(void*)ob_type==(void*)&amp;python312.dll!PyDict_Type" Name="[size]">((python312.dll!PyDictObject*)this)->ma_used</Item>
			<CustomListItems Condition="(void*)ob_type==(void*)&amp;python312.dll!PyDict_Type">
				<Variable Name="ma_used" InitialValue="((python312.dll!PyDictObject*)this)->ma_used"/>
				<Variable Name="ma_keys" InitialValue="((python312.dll!PyDictObject*)this)->ma_keys"/>
				<Variable Name="dk_kind" InitialValue="ma_keys->dk_kind"/>
				<Variable Name="dk_nentries" InitialValue="ma_keys->dk_nentries"/>
				<Variable Name="skey_entry" InitialValue="((python312.dll!PyDictKeyEntry*)(&amp;((int8_t*)((ma_keys)->dk_indices))[(size_t)1&lt;&lt;(ma_keys)->dk_log2_size]))"/>
				<Variable Name="ukey_entry" InitialValue="((python312.dll!PyDictUnicodeEntry*)(&amp;((int8_t*)((ma_keys)->dk_indices))[(size_t)1&lt;&lt;(ma_keys)->dk_log2_size]))"/>
				<Variable Name="ma_values" InitialValue="((python312.dll!PyDictObject*)this)->ma_values"/>
				<Variable Name="i" InitialValue="0"/>
				<Variable Name="j" InitialValue="0"/>
				<!-- 遍历ma_keys-->
				<Loop Condition="ma_values==nullptr &amp;&amp; i&lt;dk_nentries">
					<Exec>j=i</Exec>
					<Exec>i++</Exec>
					<!-- PyDictKeyEntry -->
					<Loop Condition="j&lt;dk_nentries &amp;&amp; dk_kind==0 &amp;&amp; skey_entry[j].me_value==nullptr">
						<Exec>j++</Exec>
					</Loop>
					<Item Condition="dk_kind==0" Name="{skey_entry[j].me_key,na}">skey_entry[j].me_value,na</Item>
					<!-- PyDictUnicodeEntry -->
					<Loop Condition="j&lt;dk_nentries &amp;&amp; dk_kind!=0 &amp;&amp; ukey_entry[j].me_value==nullptr">
						<Exec>j++</Exec>
					</Loop>
					<Item Condition="dk_kind!=0" Name="{ukey_entry[j].me_key,na}">ukey_entry[j].me_value,na</Item>
				</Loop>
				<!-- 遍历ma_values-->
				<Loop Condition="ma_values!=nullptr &amp;&amp; i&lt;ma_used">
					<Exec>j=((char*)ma_values)[-3-i]</Exec>
					<Exec>i++</Exec>
					<Item Name="{ukey_entry[j].me_key,na}">ma_values->values[j],na</Item>
				</Loop>
			</CustomListItems>
